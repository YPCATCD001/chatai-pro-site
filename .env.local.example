# ============================================================
# ChatAI Pro — 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值
# ============================================================

# ---- 1. Supabase（必须）----
# 在 Supabase Dashboard → Project Settings → API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- 2. DeepSeek AI（必须）----
# 在 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：指定模型（默认 deepseek-chat）
DEEPSEEK_CHAT_MODEL=deepseek-chat

# ---- 3. 应用 URL（必须）----
# 部署后你的 Vercel 域名或自定义域名
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ---- 4. Stripe 支付（可选）----
# 在 https://dashboard.stripe.com/apikeys 获取
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 安全提示：
#   - 永远不要把 .env.local 提交到 Git
#   - service_role key 只应在服务器端使用（API routes）
#   - 在 Vercel 中通过 Project Settings → Environment Variables 配置
# ============================================================
